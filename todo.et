15.2 regexp operators
# replace
    (re`\s`i : `-`) /~ 'source string abc'
    re`\s`i >> "-" /~ 'source string abc'
    re`\s`i / "-" /~ 'source string abc'
    'source string abc' <= (re`\s`i /~ ,'-')
    'source string abc' -+ (re`\s`i /~ ,'-')

# split 
    - overloaded `/`
    'source string' / re`\s+`
    # str-str split
    'source string abc' / ' '


