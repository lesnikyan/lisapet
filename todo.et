14.9.2 think about transfer matched regexp into sub-expression 
match s

    pattern@re`\d+([a-z]+)` !- res = pattern ?~ s
    pattern := re`\d+([a-z]+)`i !- 
    re`\d+([a-z]+)` => rx !- res = split(s, rx)
    re`\d+([a-z]+)` => p@(x) !- 
    
    # assign matched val
    val@re`abc` /: res = val
    
    # assign matched regexp
    re`abc`@rx /: res = rx ?~ s
    rx @~ re`abc` /: res = rx ?~ s

# transfer found groups
    re`(\d+) (\w+)` :> a, b !- print(a, b)

# transfer regexp from pattern
    should be different from `@`-assignment 
    ptt <?> re`(sub)` !- res = ptt ?~ sourceString 


